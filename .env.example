# Environment Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
DATABASE_URL=postgresql://postgres:password@postgres:5432/financial_events
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_ENABLED=true
REDIS_LOCK_ENABLED=true
IDEMPOTENCY_CACHE_ENABLED=true
REDIS_LOCK_TTL_MS=3000
REDIS_IDEMPOTENCY_CACHE_TTL_SECONDS=86400
REDIS_SOCKET_TIMEOUT_MS=200

# Phase 7 HMAC Security
HMAC_ENABLED=true
HMAC_ALLOWED_SKEW_SECONDS=300
EXTERNAL_CLIENT_SECRETS=bank-a:dummy-not-a-real-secret,broker-b:dummy-not-a-real-secret
ENABLE_PARTNER_HMAC_AUTH=false
PARTNER_HMAC_TIMESTAMP_SKEW_SECONDS=300
PARTNER_HMAC_ALLOW_NEXT_DRY_RUN=false
# Format: client_id|key_id|status|dummy_value|previous_valid_until_iso|enabled
PARTNER_HMAC_SECRETS=bank-a|key-current|current|dummy-not-a-real-secret||true

# Application Configuration
APP_NAME=financial-event-api
APP_ENV=local
DEBUG=false
API_PREFIX=/api/v1
METRICS_ENABLED=true

# API Runtime
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
WRITE_SUSPEND_STATE_FILE=reports/runtime/write-suspend-state.json
WRITE_SUSPEND_RETRY_AFTER_SECONDS=30
RECOVERY_ADMIN_API_ENABLED=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# External System API Keys
EXTERNAL_SYSTEM_API_KEY_BANK_A=your-bank-a-key-here
EXTERNAL_SYSTEM_API_KEY_BANK_B=your-bank-b-key-here

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# Prometheus Metrics
PROMETHEUS_PORT=9090

# Feature Flags
FEATURE_REDIS_ENABLED=true
FEATURE_CONSISTENCY_CHECK_ENABLED=true

# Monitoring & Alerting
ALERT_ON_DUPLICATE=true
ALERT_ON_INVALID_STATE_TRANSITION=true
